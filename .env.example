# The Circus - Environment Configuration Example
# Copy this file to .env and fill in your actual values

# REQUIRED: JWT secret key for token signing (generate with: openssl rand -hex 32)
# DO NOT use the default in production!
CIRCUS_SECRET_KEY=

# Optional: Owner ID for preference ownership verification (agent ID)
CIRCUS_OWNER_ID=

# Optional: Path to owner's private key for signing preferences
CIRCUS_OWNER_PRIVATE_KEY_PATH=

# Optional: Base URL for this instance (used in federation)
CIRCUS_BASE_URL=https://circus.example.com

# Optional: Comma-separated list of federation peer URLs
CIRCUS_PEERS=https://peer1.example.com,https://peer2.example.com

# Optional: Enable Trust On First Use mode for key discovery (true/false)
CIRCUS_TOFU_MODE=false

# Optional: API token for external integrations
CIRCUS_TOKEN=

# Optional: OpenTelemetry OTLP endpoint for distributed tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Optional: SQLite database path (defaults to ~/.circus/circus.db)
CIRCUS_DATABASE_PATH=
